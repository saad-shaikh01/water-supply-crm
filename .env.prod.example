# Copy this file to .env.prod and replace every placeholder before the first production deploy.
# `docker compose --env-file .env.prod -f docker-compose.prod.yml` uses this file for:
# 1. Compose-time variable interpolation
# 2. Runtime env injection into `api-backend`
# 3. Build args for the Next.js frontend images

# ─── Required: PostgreSQL container bootstrap ──────────────────────────────────
POSTGRES_USER=wscrm
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=water_supply_crm

# ─── Required: backend auth / API base URLs ────────────────────────────────────
JWT_SECRET=replace-with-a-32-plus-char-random-secret
NEXT_PUBLIC_API_URL=https://backend.testinglinq.com/api

# ─── Optional: email-based password resets ─────────────────────────────────────
# Limitation: the backend currently supports one reset-link base URL via FRONTEND_URL.
# Point it at the frontend that should own `/reset-password` in production.
FRONTEND_URL=https://admin.testinglinq.com/auth
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=postmaster@testinglinq.com
MAIL_PASS=replace-with-smtp-password
MAIL_FROM="Water Supply CRM <noreply@testinglinq.com>"

# ─── Optional: S3-compatible object storage for screenshots / attachments ──────
WASABI_ACCESS_KEY_ID=replace-with-access-key
WASABI_SECRET_ACCESS_KEY=replace-with-secret-key
WASABI_REGION=ap-southeast-1
WASABI_BUCKET=wscrm-uploads
WASABI_ENDPOINT=https://s3.ap-southeast-1.wasabisys.com

# ─── Optional: Paymob / Raast payment integration ──────────────────────────────
# Required only if hosted payment / webhook flows are enabled.
API_URL=https://backend.testinglinq.com/api
PAYMOB_API_KEY=replace-with-paymob-api-key
PAYMOB_RAAST_INTEGRATION_ID=replace-with-integration-id
PAYMOB_HMAC_SECRET=replace-with-hmac-secret
PAYMOB_BASE_URL=https://accept.paymob.com/api

# ─── Optional: vendor live-tracking map ────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.replace-with-mapbox-token

# ─── Optional: browser-side Firebase config for push notifications ─────────────
# Used by `vendor-dashboard` and `customer-portal`.
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-web-api-key
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=testinglinq.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_PROJECT_ID=testinglinq
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=testinglinq.appspot.com
# Preferred key used by the frontend notification setup.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=replace-with-web-push-vapid-key
# Legacy fallback still supported by the codebase; keep blank unless you need it.
NEXT_PUBLIC_FIREBASE_MESSAGING_VAPID_KEY=

# ─── Optional: Firebase Admin SDK for backend FCM delivery ─────────────────────
# Required if the backend should send push notifications.
FIREBASE_PROJECT_ID=testinglinq
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@testinglinq.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"

# ─── Optional: WhatsApp automation ──────────────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=/app/whatsapp-session
CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Optional: backend logging ─────────────────────────────────────────────────
LOG_LEVEL=info
