# Copy this file to .env.prod and fill in the real values before deploying.
# docker-compose.prod.yml reads .env.prod at runtime AND as build args.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=wscrm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=water_supply_crm

# ─── Message queue ────────────────────────────────────────────────────────────
RABBITMQ_USER=wscrm
RABBITMQ_PASS=change-me

# ─── API backend secrets ──────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string

# ─── Next.js public vars (baked into browser bundles at image build time) ─────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Mapbox (vendor-dashboard only)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Firebase (both apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_VAPID_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── WhatsApp (optional) ──────────────────────────────────────────────────────
# Set WHATSAPP_ENABLED=true to activate. On first start, a QR code will be
# printed in the api-backend container logs — scan it once with the business
# phone. The auth session is persisted in the whatsapp_session Docker volume
# so subsequent restarts do not require a re-scan.
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=/app/whatsapp-session
# Path to Chromium inside the container (matches Alpine's chromium package).
# Only override this if you supply a custom browser build in your image.
CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Optional backend services ────────────────────────────────────────────────
LOG_LEVEL=info
