generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentType {
  MONTHLY
  CASH
}

enum UserRole {
  SUPER_ADMIN
  VENDOR_ADMIN
  STAFF
  DRIVER
  CUSTOMER
}

enum DeliveryStatus {
  PENDING
  COMPLETED
  EMPTY_ONLY
  NOT_AVAILABLE
  RESCHEDULED
  CANCELLED
}

enum DeliveryType {
  SCHEDULED
  ON_DEMAND
}

enum TransactionType {
  DELIVERY
  COLLECTION
  PAYMENT
  ADJUSTMENT
  LOAD_OUT
  CHECK_IN
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  SALARY
  REPAIR
  OTHER
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String?
  logoUrl     String?
  // Payment settings
  raastId     String?  // Vendor's Raast ID for static QR / reference
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                   User[]
  products                Product[]
  customers               Customer[]
  vans                    Van[]
  routes                  Route[]
  dailySheets             DailySheet[]
  transactions            Transaction[]
  paymentRequests         PaymentRequest[]
  expenses                Expense[]
  orders                  CustomerOrder[]
  tickets                 CustomerTicket[]
  deliveryIssues          DeliveryIssue[]
  reminderScheduleConfig  ReminderScheduleConfig?
  driverLastLocations     DriverLastLocation[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  phoneNumber   String?  @unique
  role          UserRole
  isActive      Boolean  @default(true)
  vendorId      String?
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  
  // Relations for specific roles
  assignedVan         Van?     @relation("VanDriver")
  dailySheets         DailySheet[] @relation("DriverSheets")
  customer            Customer? // One-to-one link for Customer Portal
  expenses            Expense[]
  fcmTokens             FcmToken[]
  inAppNotifications    InAppNotification[]
  notificationPrefs     NotificationPreference[]
  driverLastLocation    DriverLastLocation?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  isActive    Boolean  @default(true)

  wallets     BottleWallet[]
  sheetItems  DailySheetItem[]
  transactions Transaction[]
  customPrices CustomerProductPrice[]
  orders      CustomerOrder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId, isActive])
}

model Customer {
  id            String   @id @default(uuid())
  customerCode  String   @unique
  name          String
  phoneNumber   String

  // Location
  address              String
  floor                String?  // e.g. "2nd Floor", "Flat 3B"
  nearbyLandmark       String?  // e.g. "Near McDonald's", "Opposite mosque"
  deliveryInstructions String?  // e.g. "Call before arriving", "Leave at gate"
  googleMapsUrl        String?  // Full Google Maps share URL (lat/lng parsed on frontend)
  latitude             Float?
  longitude            Float?

  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  routeId       String?  // Optional "home route" for organizational grouping only
  route         Route?   @relation(fields: [routeId], references: [id])

  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  paymentType      PaymentType @default(CASH)
  isActive         Boolean     @default(true)
  financialBalance Float       @default(0) // Current outstanding amount (running balance)

  wallets           BottleWallet[]
  customPrices      CustomerProductPrice[]
  sheetItems        DailySheetItem[]
  transactions      Transaction[]
  paymentRequests   PaymentRequest[]
  deliverySchedules CustomerDeliverySchedule[]
  orders            CustomerOrder[]
  tickets           CustomerTicket[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
  @@index([vendorId, routeId])
  @@index([routeId])
}

model CustomerDeliverySchedule {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vanId         String
  van           Van      @relation(fields: [vanId], references: [id])
  dayOfWeek     Int      // 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  routeSequence Int?     // Position in van's delivery order on this day
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerId, dayOfWeek])
  @@index([vanId, dayOfWeek])
}

model CustomerProductPrice {
  id          String   @id @default(uuid())
  customerId  String
  productId   String
  customPrice Float
  
  customer    Customer @relation(fields: [customerId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model BottleWallet {
  id          String   @id @default(uuid())
  customerId  String
  productId   String
  balance     Int      @default(0) // Current bottles at customer location
  
  customer    Customer @relation(fields: [customerId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model Route {
  id            String   @id @default(uuid())
  name          String
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  defaultVanId  String?
  defaultVan    Van?     @relation("RouteDefaultVan", fields: [defaultVanId], references: [id])

  customers     Customer[]
  dailySheets   DailySheet[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
}

model Van {
  id            String   @id @default(uuid())
  plateNumber   String   @unique
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  isActive        Boolean @default(true)
  defaultDriverId String? @unique
  defaultDriver   User?   @relation("VanDriver", fields: [defaultDriverId], references: [id])

  routes            Route[]  @relation("RouteDefaultVan")
  dailySheets       DailySheet[]
  expenses          Expense[]
  deliverySchedules CustomerDeliverySchedule[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DailySheet {
  id            String   @id @default(uuid())
  date          DateTime
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  routeId       String?
  route         Route?   @relation(fields: [routeId], references: [id])
  
  vanId         String
  van           Van      @relation(fields: [vanId], references: [id])
  
  driverId      String
  driver        User     @relation("DriverSheets", fields: [driverId], references: [id])
  
  isClosed      Boolean  @default(false)
  
  // Reconciliation fields
  filledOutCount Int     @default(0)
  filledInCount  Int     @default(0)
  emptyInCount   Int     @default(0)
  cashExpected   Float   @default(0)
  cashCollected  Float   @default(0)

  items         DailySheetItem[]
  transactions  Transaction[]
  loads         DailySheetLoad[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId, date])
  @@index([vendorId, routeId, date])
  @@index([driverId, date])
}

model DailySheetLoad {
  id             String     @id @default(uuid())
  dailySheetId   String
  dailySheet     DailySheet @relation(fields: [dailySheetId], references: [id], onDelete: Cascade)
  tripNumber     Int        // 1, 2, 3...
  loadedFilled   Int        // filled bottles taken from warehouse at trip start
  returnedFilled Int        @default(0)  // filled returned at end of trip
  collectedEmpty Int        @default(0)  // empties collected from customers
  cashHandedIn   Float      @default(0)  // cash given to warehouse at check-in
  startedAt      DateTime   @default(now())
  endedAt        DateTime?  // null = trip still in progress

  @@index([dailySheetId])
}

model DailySheetItem {
  id            String   @id @default(uuid())
  dailySheetId  String
  dailySheet    DailySheet @relation(fields: [dailySheetId], references: [id])
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  
  sequence      Int
  status        DeliveryStatus @default(PENDING)
  deliveryType  DeliveryType   @default(SCHEDULED)
  sourceOrderId String?

  filledDropped Int      @default(0)
  emptyReceived Int      @default(0)
  cashCollected Float    @default(0)
  
  reason          String?  // Free text notes for unable-to-deliver
  failureCategory String?  // CUSTOMER_NOT_HOME | CUSTOMER_NOT_ANSWERING | CUSTOMER_SELF_PICKUP | VAN_BREAKDOWN | ACCESS_ISSUE | CUSTOMER_REFUSED | WEATHER | OTHER
  photoUrl        String?  // Optional photo evidence
  rescheduledTo DateTime?

  deliveryIssue DeliveryIssue?
  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dailySheetId, sequence])
  @@index([dailySheetId, customerId])
}

model DeliveryIssue {
  id               String              @id @default(uuid())
  vendorId         String
  vendor           Vendor              @relation(fields: [vendorId], references: [id])

  dailySheetItemId String              @unique
  dailySheetItem   DailySheetItem      @relation(fields: [dailySheetItemId], references: [id])

  status           DeliveryIssueStatus @default(OPEN)

  // Plan fields
  nextAction       IssueNextAction?
  retryAt          DateTime?
  assignedToUserId String?
  assignedVanId    String?
  assignedDriverId String?
  planNotes        String?
  plannedAt        DateTime?
  plannedById      String?

  // Resolution fields
  resolution       IssueResolution?
  resolvedNotes    String?
  resolvedAt       DateTime?
  resolvedById     String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([vendorId, status])
  @@index([vendorId, createdAt])
}

model Transaction {
  id            String   @id @default(uuid())
  type          TransactionType
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])
  
  dailySheetId     String?
  dailySheet       DailySheet?     @relation(fields: [dailySheetId], references: [id])

  dailySheetItemId String?
  dailySheetItem   DailySheetItem? @relation(fields: [dailySheetItemId], references: [id], onDelete: SetNull)

  bottleCount   Int?     // NET change to wallet (filledDropped - emptyReceived)
  filledDropped Int?     // Filled bottles given to customer (consumption indicator)
  emptyReceived Int?     // Empty bottles collected from customer
  amount        Float?   // Positive for charge, negative for payment

  description   String?

  createdAt     DateTime @default(now())

  @@index([vendorId, createdAt])
  @@index([customerId, createdAt])
  @@index([dailySheetId])
  @@index([dailySheetItemId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Payment Requests
// ──────────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────────
// Customer Orders & Support Tickets
// ──────────────────────────────────────────────────────────────────────────────

enum DeliveryIssueStatus {
  OPEN
  PLANNED
  IN_RETRY
  RESOLVED
  DROPPED
}

enum IssueNextAction {
  RETRY_SAME_DAY
  RETRY_ON_DATE_TIME
  MOVE_TO_NEXT_REGULAR_DAY
  SELF_PICKUP
  CANCEL_ONE_OFF
  PERMANENT_STOP
}

enum IssueResolution {
  DELIVERED
  SELF_PICKUP_DONE
  DROPPED
  CANCELLED
}

enum DispatchStatus {
  UNPLANNED
  PLANNED
  INSERTED_IN_SHEET
  DELIVERED
  FAILED
  SELF_PICKUP_DONE
  CANCELLED
}

enum DispatchMode {
  INSERT_IN_OPEN_SHEET
  QUEUE_FOR_GENERATION
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TicketType {
  FEEDBACK
  COMPLAINT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model CustomerOrder {
  id              String      @id @default(cuid())
  vendorId        String
  customerId      String
  productId       String
  quantity        Int
  status          OrderStatus @default(PENDING)
  note            String?
  preferredDate   DateTime?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  // Dispatch planning
  dispatchStatus   DispatchStatus @default(UNPLANNED)
  targetDate       DateTime?
  timeWindow       String?
  dispatchVanId    String?
  dispatchDriverId String?
  dispatchMode     DispatchMode?
  dispatchNotes    String?
  plannedAt        DateTime?
  plannedById      String?
  dispatchedAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([vendorId, status])
  @@index([vendorId, dispatchStatus])
  @@index([customerId])
}

model CustomerTicket {
  id          String         @id @default(cuid())
  vendorId    String
  customerId  String
  type        TicketType
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(NORMAL)
  vendorReply String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  messages TicketMessage[]

  @@index([vendorId, status])
  @@index([customerId])
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      CustomerTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderRole  String   // "CUSTOMER" | "VENDOR"
  senderId    String
  message     String
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

enum PaymentRequestStatus {
  PENDING     // Manual: submitted by customer, waiting vendor review
              // Raast QR: QR generated, waiting scan
  PROCESSING  // Raast QR: customer scanning / payment in progress
  PAID        // Gateway confirmed payment (Raast QR auto-approved)
  APPROVED    // Vendor manually approved (manual payments)
  REJECTED    // Vendor rejected
  EXPIRED     // QR expired without payment
  CANCELLED   // Customer cancelled
}

enum PaymentMethod {
  RAAST_QR          // Automated via Paymob — QR generated, customer scans
  MANUAL_RAAST      // Customer paid via Raast, submitted reference number
  MANUAL_JAZZCASH   // Customer paid via JazzCash, submitted reference
  MANUAL_EASYPAISA  // Customer paid via Easypaisa, submitted reference
  MANUAL_BANK       // Customer paid via bank transfer / IBFT
}

model PaymentRequest {
  id         String               @id @default(uuid())
  vendorId   String
  customerId String
  amount     Float

  method  PaymentMethod
  status  PaymentRequestStatus @default(PENDING)

  // ── Raast QR (automated) ─────────────────────────────────────────────
  gatewayOrderId  String?   // Paymob order ID
  gatewayTxId     String?   // Paymob transaction ID (set on webhook)
  checkoutUrl     String?   // Paymob hosted checkout URL
  qrCodeData      String?   // QR image base64 or URL (if returned by gateway)
  qrExpiresAt     DateTime? // QR expiry (typically 10-15 min)

  // ── Manual payment ───────────────────────────────────────────────────
  referenceNo    String?   // Transaction ID / reference entered by customer
  screenshotPath String?   // Local path to uploaded screenshot
  customerNote   String?   // Optional message from customer

  // ── Review (vendor) ──────────────────────────────────────────────────
  reviewedBy      String?   // userId of vendor admin who approved/rejected
  reviewedAt      DateTime?
  rejectionReason String?

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, status])
  @@index([customerId])
  @@index([gatewayOrderId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Expense Tracking
// ──────────────────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  vendorId    String
  vendor      Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Float
  description String
  date        DateTime
  vanId       String?
  van         Van?            @relation(fields: [vanId], references: [id])
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([vendorId, date])
  @@index([vendorId, category])
}

// ──────────────────────────────────────────────────────────────────────────────
// FCM Push Tokens
// ──────────────────────────────────────────────────────────────────────────────

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Audit Log
// ──────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  vendorId  String?
  userId    String?
  userName  String?
  action    String   // "CREATE" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT" | "SUSPEND" etc.
  entity    String   // "Customer" | "Payment" | "User" etc.
  entityId  String?
  changes   Json?    // { before: {}, after: {} }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, createdAt])
  @@index([entity, entityId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Notification Platform
// ──────────────────────────────────────────────────────────────────────────────

model InAppNotification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId  String?
  type      String    // e.g. ORDER_APPROVED | TICKET_REPLIED | PAYMENT_APPROVED
  title     String
  message   String
  entityId  String?   // orderId, ticketId, paymentRequestId, etc.
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String   // e.g. order.approved
  channel   String   // WHATSAPP | SMS | FCM | IN_APP
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([userId, eventType, channel])
  @@index([userId])
}

model NotificationLog {
  id               String    @id @default(uuid())
  channel          String    // WHATSAPP | SMS | FCM | IN_APP
  status           String    // SENT | FAILED
  recipientAddress String?   // phone number or FCM userId
  eventType        String?   // e.g. order.approved
  entityType       String?   // ORDER | PAYMENT | TICKET
  entityId         String?
  recipientType    String?   // CUSTOMER | USER
  recipientId      String?
  vendorId         String?
  attemptCount     Int       @default(1)
  lastError        String?
  queuedAt         DateTime
  sentAt           DateTime?
  failedAt         DateTime?
  createdAt        DateTime  @default(now())

  @@index([channel, status])
  @@index([vendorId, createdAt])
  @@index([createdAt])
}
// ──────────────────────────────────────────────────────────────────────────────
// Balance Reminder Schedule Config
// ──────────────────────────────────────────────────────────────────────────────

model ReminderScheduleConfig {
  id             String   @id @default(uuid())
  vendorId       String   @unique
  vendor         Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  cronExpression String
  minBalance     Int      @default(100)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([vendorId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Driver Last-Known Location (persistent, DB-backed)
// Redis holds the live stream; this table holds the last-known record so
// offline drivers are not silently lost when the Redis key expires.
// ──────────────────────────────────────────────────────────────────────────────

model DriverLastLocation {
  id           String   @id @default(uuid())
  driverId     String   @unique
  driver       User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  latitude     Float
  longitude    Float
  speed        Float?
  bearing      Float?
  /// ONLINE | DELIVERING | AWAY — last self-reported status
  status       String   @default("ONLINE")
  vanId        String?
  dailySheetId String?
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vendorId])
  @@index([vendorId, lastSeenAt])
}
