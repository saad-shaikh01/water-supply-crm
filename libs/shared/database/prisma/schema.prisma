generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentType {
  MONTHLY
  CASH
}

enum UserRole {
  SUPER_ADMIN
  VENDOR_ADMIN
  STAFF
  DRIVER
  CUSTOMER
}

enum DeliveryStatus {
  PENDING
  COMPLETED
  EMPTY_ONLY
  NOT_AVAILABLE
  RESCHEDULED
  CANCELLED
}

enum TransactionType {
  DELIVERY
  COLLECTION
  PAYMENT
  ADJUSTMENT
  LOAD_OUT
  CHECK_IN
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  SALARY
  REPAIR
  OTHER
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String?
  logoUrl     String?
  // Payment settings
  raastId     String?  // Vendor's Raast ID for static QR / reference
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  products        Product[]
  customers       Customer[]
  vans            Van[]
  routes          Route[]
  dailySheets     DailySheet[]
  transactions    Transaction[]
  paymentRequests PaymentRequest[]
  expenses        Expense[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  phoneNumber   String?  @unique
  role          UserRole
  isActive      Boolean  @default(true)
  vendorId      String?
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  
  // Relations for specific roles
  assignedVan   Van?     @relation("VanDriver")
  dailySheets   DailySheet[] @relation("DriverSheets")
  customer      Customer? // One-to-one link for Customer Portal
  expenses      Expense[]
  fcmTokens     FcmToken[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  isActive    Boolean  @default(true)

  wallets     BottleWallet[]
  sheetItems  DailySheetItem[]
  transactions Transaction[]
  customPrices CustomerProductPrice[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId, isActive])
}

model Customer {
  id            String   @id @default(uuid())
  customerCode  String   @unique
  name          String
  phoneNumber   String

  // Location
  address              String
  floor                String?  // e.g. "2nd Floor", "Flat 3B"
  nearbyLandmark       String?  // e.g. "Near McDonald's", "Opposite mosque"
  deliveryInstructions String?  // e.g. "Call before arriving", "Leave at gate"
  googleMapsUrl        String?  // Full Google Maps share URL (lat/lng parsed on frontend)
  latitude             Float?
  longitude            Float?

  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  routeId       String?  // Optional "home route" for organizational grouping only
  route         Route?   @relation(fields: [routeId], references: [id])

  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  paymentType      PaymentType @default(CASH)
  isActive         Boolean     @default(true)
  financialBalance Float       @default(0) // Current outstanding amount (running balance)

  wallets           BottleWallet[]
  customPrices      CustomerProductPrice[]
  sheetItems        DailySheetItem[]
  transactions      Transaction[]
  paymentRequests   PaymentRequest[]
  deliverySchedules CustomerDeliverySchedule[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
  @@index([vendorId, routeId])
  @@index([routeId])
}

model CustomerDeliverySchedule {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vanId         String
  van           Van      @relation(fields: [vanId], references: [id])
  dayOfWeek     Int      // 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  routeSequence Int?     // Position in van's delivery order on this day
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerId, dayOfWeek])
  @@index([vanId, dayOfWeek])
}

model CustomerProductPrice {
  id          String   @id @default(uuid())
  customerId  String
  productId   String
  customPrice Float
  
  customer    Customer @relation(fields: [customerId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model BottleWallet {
  id          String   @id @default(uuid())
  customerId  String
  productId   String
  balance     Int      @default(0) // Current bottles at customer location
  
  customer    Customer @relation(fields: [customerId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
}

model Route {
  id            String   @id @default(uuid())
  name          String
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  defaultVanId  String?
  defaultVan    Van?     @relation("RouteDefaultVan", fields: [defaultVanId], references: [id])

  customers     Customer[]
  dailySheets   DailySheet[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
}

model Van {
  id            String   @id @default(uuid())
  plateNumber   String   @unique
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  isActive        Boolean @default(true)
  defaultDriverId String? @unique
  defaultDriver   User?   @relation("VanDriver", fields: [defaultDriverId], references: [id])

  routes            Route[]  @relation("RouteDefaultVan")
  dailySheets       DailySheet[]
  expenses          Expense[]
  deliverySchedules CustomerDeliverySchedule[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DailySheet {
  id            String   @id @default(uuid())
  date          DateTime
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  routeId       String?
  route         Route?   @relation(fields: [routeId], references: [id])
  
  vanId         String
  van           Van      @relation(fields: [vanId], references: [id])
  
  driverId      String
  driver        User     @relation("DriverSheets", fields: [driverId], references: [id])
  
  isClosed      Boolean  @default(false)
  
  // Reconciliation fields
  filledOutCount Int     @default(0)
  filledInCount  Int     @default(0)
  emptyInCount   Int     @default(0)
  cashExpected   Float   @default(0)
  cashCollected  Float   @default(0)

  items         DailySheetItem[]
  transactions  Transaction[]
  loads         DailySheetLoad[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId, date])
  @@index([vendorId, routeId, date])
  @@index([driverId, date])
}

model DailySheetLoad {
  id             String     @id @default(uuid())
  dailySheetId   String
  dailySheet     DailySheet @relation(fields: [dailySheetId], references: [id], onDelete: Cascade)
  tripNumber     Int        // 1, 2, 3...
  loadedFilled   Int        // filled bottles taken from warehouse at trip start
  returnedFilled Int        @default(0)  // filled returned at end of trip
  collectedEmpty Int        @default(0)  // empties collected from customers
  cashHandedIn   Float      @default(0)  // cash given to warehouse at check-in
  startedAt      DateTime   @default(now())
  endedAt        DateTime?  // null = trip still in progress

  @@index([dailySheetId])
}

model DailySheetItem {
  id            String   @id @default(uuid())
  dailySheetId  String
  dailySheet    DailySheet @relation(fields: [dailySheetId], references: [id])
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  
  sequence      Int
  status        DeliveryStatus @default(PENDING)
  
  filledDropped Int      @default(0)
  emptyReceived Int      @default(0)
  cashCollected Float    @default(0)
  
  reason          String?  // Free text notes for unable-to-deliver
  failureCategory String?  // CUSTOMER_NOT_HOME | CUSTOMER_NOT_ANSWERING | CUSTOMER_SELF_PICKUP | VAN_BREAKDOWN | ACCESS_ISSUE | CUSTOMER_REFUSED | WEATHER | OTHER
  photoUrl        String?  // Optional photo evidence
  rescheduledTo DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dailySheetId, sequence])
  @@index([dailySheetId, customerId])
}

model Transaction {
  id            String   @id @default(uuid())
  type          TransactionType
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])
  
  dailySheetId  String?
  dailySheet    DailySheet? @relation(fields: [dailySheetId], references: [id])
  
  bottleCount   Int?     // NET change to wallet (filledDropped - emptyReceived)
  filledDropped Int?     // Filled bottles given to customer (consumption indicator)
  emptyReceived Int?     // Empty bottles collected from customer
  amount        Float?   // Positive for charge, negative for payment

  description   String?

  createdAt     DateTime @default(now())

  @@index([vendorId, createdAt])
  @@index([customerId, createdAt])
  @@index([dailySheetId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Payment Requests
// ──────────────────────────────────────────────────────────────────────────────

enum PaymentRequestStatus {
  PENDING     // Manual: submitted by customer, waiting vendor review
              // Raast QR: QR generated, waiting scan
  PROCESSING  // Raast QR: customer scanning / payment in progress
  PAID        // Gateway confirmed payment (Raast QR auto-approved)
  APPROVED    // Vendor manually approved (manual payments)
  REJECTED    // Vendor rejected
  EXPIRED     // QR expired without payment
  CANCELLED   // Customer cancelled
}

enum PaymentMethod {
  RAAST_QR          // Automated via Paymob — QR generated, customer scans
  MANUAL_RAAST      // Customer paid via Raast, submitted reference number
  MANUAL_JAZZCASH   // Customer paid via JazzCash, submitted reference
  MANUAL_EASYPAISA  // Customer paid via Easypaisa, submitted reference
  MANUAL_BANK       // Customer paid via bank transfer / IBFT
}

model PaymentRequest {
  id         String               @id @default(uuid())
  vendorId   String
  customerId String
  amount     Float

  method  PaymentMethod
  status  PaymentRequestStatus @default(PENDING)

  // ── Raast QR (automated) ─────────────────────────────────────────────
  gatewayOrderId  String?   // Paymob order ID
  gatewayTxId     String?   // Paymob transaction ID (set on webhook)
  checkoutUrl     String?   // Paymob hosted checkout URL
  qrCodeData      String?   // QR image base64 or URL (if returned by gateway)
  qrExpiresAt     DateTime? // QR expiry (typically 10-15 min)

  // ── Manual payment ───────────────────────────────────────────────────
  referenceNo    String?   // Transaction ID / reference entered by customer
  screenshotPath String?   // Local path to uploaded screenshot
  customerNote   String?   // Optional message from customer

  // ── Review (vendor) ──────────────────────────────────────────────────
  reviewedBy      String?   // userId of vendor admin who approved/rejected
  reviewedAt      DateTime?
  rejectionReason String?

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, status])
  @@index([customerId])
  @@index([gatewayOrderId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Expense Tracking
// ──────────────────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  vendorId    String
  vendor      Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Float
  description String
  date        DateTime
  vanId       String?
  van         Van?            @relation(fields: [vanId], references: [id])
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([vendorId, date])
  @@index([vendorId, category])
}

// ──────────────────────────────────────────────────────────────────────────────
// FCM Push Tokens
// ──────────────────────────────────────────────────────────────────────────────

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Audit Log
// ──────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  vendorId  String?
  userId    String?
  userName  String?
  action    String   // "CREATE" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT" | "SUSPEND" etc.
  entity    String   // "Customer" | "Payment" | "User" etc.
  entityId  String?
  changes   Json?    // { before: {}, after: {} }
  createdAt DateTime @default(now())

  @@index([vendorId, createdAt])
  @@index([entity, entityId])
}