{
        "name": "vendor-dashboard",
        "$schema": "../../node_modules/nx/schemas/project-schema.json",
        "sourceRoot": "apps/vendor-dashboard",
        "projectType": "application",
        "tags": [],
        "// targets": "to see all targets run: nx show project vendor-dashboard --web",
        "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/vendor-dashboard"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/vendor-dashboard"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "vendor-dashboard:build",
        "dev": true,
        "port": 4201
      },
      "configurations": {
        "development": {
          "buildTarget": "vendor-dashboard:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "vendor-dashboard:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}