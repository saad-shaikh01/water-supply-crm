{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@water-supply-crm/ui": ["libs/shared/ui/src/index.ts"],
      "@water-supply-crm/ui/styles.css": ["libs/shared/ui/src/styles.css"],
      "@water-supply-crm/types": ["libs/shared/types/src/index.ts"],
      "@water-supply-crm/data-access": ["libs/shared/data-access/src/index.ts"],
      "@water-supply-crm/database": ["libs/shared/database/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
