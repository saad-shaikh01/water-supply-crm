POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=water_supply_crm

RABBITMQ_USER=user
RABBITMQ_PASS=password

# Connect to Localhost (for running apps on host)
DATABASE_URL="postgresql://admin:admin123@localhost:5432/water_supply_crm?schema=public"
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://user:password@localhost:5672"

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123

# Wasabi S3-compatible object storage (payment screenshots + ticket attachments)
WASABI_ACCESS_KEY_ID=your-wasabi-access-key
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-key
WASABI_REGION=ap-southeast-1
WASABI_BUCKET=wscrm-uploads
WASABI_ENDPOINT=https://s3.ap-southeast-1.wasabisys.com
# Optional: CDN or custom public base URL (defaults to WASABI_ENDPOINT/WASABI_BUCKET)
# WASABI_PUBLIC_URL=https://cdn.example.com
